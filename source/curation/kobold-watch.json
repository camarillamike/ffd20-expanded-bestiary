        {
          "name": "Bond to the Land",
          "type": "ex",
          "description": "Kobold gain a +2 dodge bonus to AC when in caves and rocky terrain.",
          "notes": {
            "familiar": ""
          }
        },
        {
          "name": "Cave Dweller",
          "type": "ex",
          "description": "Kobolds have vast knowledge on dungeons and survival and therefore gain a +2 racial bonus on Knowledge (dungeoneering) and Survival checks made underground.",
          "notes": {
            "familiar": ""
          }
        },
        {
          "name": "Emissary",
          "type": "ex",
          "description": "Kobolds are decent on making trade offers to the once famous pirates of Lominsa and know exactly how to swindle their way into getting precious metals and ores. Once per day, kobolds can roll twice when making a Bluff or Diplomacy check and take the better roll.",
          "notes": {
            "familiar": ""
          }
        },
        {
          "name": "Magic Hammer",
          "type": "su",
          "description": "Once per day, a kobold can summon a magical hammer and launches (+4 ranged touch attack) it at a single target within 30 feet for 1d4 points of MP damage. Blue mages may learn this ability as a 1st level spell (Knowledge: Local DC 17).",
          "notes": {
            "familiar": ""
          }
        },
        {
          "name": "Master Tinker",
          "type": "ex",
          "description": "Like goblins, kobolds are excellent at taking things apart, thought not as much as putting them back together and gain a +2 racial bonus on Disable Device skill checks. Kobolds are also treated as proficient with any weapon they have personally “crafted”.",
          "notes": {
            "familiar": ""
          }
        },
        {
          "name": "Reckless Work",
          "type": "ex",
          "description": "Kobolds receive a +4 racial bonus on Constitution checks and Fortitude saves to avoid fatigue and exhaustion, as well as any other ill effects from running, forced marches, starvation, thirst, and hot or cold environments.",
          "notes": {
            "familiar": ""
          }
        },
        {
          "name": "Thick Hide",
          "type": "ex",
          "description": "Kobolds have thick hair all over them and gain a +1 natural armor bonus to their Armor Class.",
          "notes": {
            "familiar": ""
          }
        }
