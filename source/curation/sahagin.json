        {
          "name": "Blood Frenzy",
          "type": "ex",
          "description": "1/day, a sahagin that takes damage in combat can fly into a frenzy in the following round. It gains +2 Constitution and +2 Strength, but takes a -2 penalty to its AC. The frenzy lasts as long as the battle or 1 minute, whichever is shorter.",
          "notes": {
            "familiar": ""
          }
        },
        {
          "name": "Bond to the Depths",
          "type": "ex",
          "description": "Sahagin gains a +2 dodge bonus to AC when in shallow and deep water terrain.",
          "notes": {
            "familiar": ""
          }
        },
        {
          "name": "Leviathan's Fury",
          "type": "su",
          "description": "1/day, Sahagin shares the power of Leviathan gaining Enwater for 2 turns or until discharged on his weapon or fist. This effect deals an extra 2 points of water damage. The weapon loses this property if its wielder drops it or otherwise loses contact with it.",
          "notes": {
            "familiar": ""
          }
        },
        {
          "name": "Martial Weapon Proficiency Trident",
          "type": "ex",
          "description": "Sahagins have been trained at birth to use tridents in hand to hand combat. They have been known to track and board trading ships throughout the generations and some have formed pirate crews to attack said ships.",
          "notes": {
            "familiar": ""
          }
        },
        {
          "name": "Mist Child",
          "type": "ex",
          "description": "Deriving from the oceans and fog, whenever a sahagin has concealment or total concealment, the miss chance of attacks against her increases by 5%.",
          "notes": {
            "familiar": ""
          }
        },
        {
          "name": "Water Gun",
